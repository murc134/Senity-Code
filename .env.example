# Senity Code - Customer Deployment Env-Template
# Kopiere nach `.env` und fuelle die Werte aus. `.env` ist gitignored.

# --- Pflicht: Senity Chat Proxy ---
# URL des Senity-Anthropic-Proxies (Default fuer Customer-Deployments).
SENITY_CHAT_PROXY_URL=https://sdr.senity.ai/api/claude-proxy

# Persoenlicher Proxy-Key (vom Senity-Admin ausgehaendigt).
SENITY_CHAT_PROXY_KEY=replace-me

# --- Optional: Image-Pinning ---
# Default = "latest". Fuer Production lieber semver pinnen.
# SENITY_IMAGE_TAG=1.4.2
SENITY_IMAGE_TAG=latest

# --- Optional: Eigene Gitea-Registry-Auth ---
# Wird beim `docker compose pull` als CLI-Login verwendet, nicht hier:
#   docker login git.senity.ai
#   Username: <Gitea-User>
#   Password: <Personal Access Token, Scope `read:package`>
