.env
start.lnk
*.lnk
workspace/
.claude/

# .bindings ist lokal pro Host (interaktiv konfigurierter Workspace-Pfad,
# eigene Mounts). Template liegt als .bindings.example im Repo; der Launcher
# kopiert es beim ersten Start.
.bindings

# Zur Laufzeit aus .env.shared dekodierte Deploy-Keys (NIE committen).
# .env.shared selbst (mit den base64-Keys) wird bewusst committet.
.deploy-keys/

# Vom Launcher erzeugte leere Overlay-Quellen fuer .bindings-Excludes.
.mount-stage/
__pycache__/
*.pyc
.DS_Store
