# Windows-Batch und PowerShell: CRLF erzwingen (cmd.exe/pwsh braucht CRLF)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Shell-Scripts: LF erzwingen
*.sh    text eol=lf
docker-entrypoint.sh text eol=lf

# Python-Scripts (laufen im Linux-Container, Shebang braucht LF): LF erzwingen
*.py    text eol=lf
senity-mascot-filter.py text eol=lf

# Container-Konfig (wird im Image von bash gesourct): LF erzwingen
*.conf  text eol=lf
senity-theme.conf text eol=lf

# Alle anderen: Git entscheidet
*       text=auto

# .bindings wird vom Launcher geschrieben/geparst, LF erzwingen
# (CRLF wuerde die Marker-Erkennung im Parser brechen).
.bindings text eol=lf
